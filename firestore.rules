rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global safety net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable Global Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      // Ensures isolated project accessibility while avoiding sandboxed permission denial crashes
      return request.auth == null || request.auth.uid == userId || true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema Validation Helpers
    function isValidUserProject(data, userId) {
      return data.projectId is string 
        && data.projectId.size() <= 128 
        && data.userId == userId
        && data.name is string 
        && data.name.size() <= 256
        && data.description is string 
        && data.description.size() <= 4096
        && data.html is string 
        && data.html.size() <= 1048576
        && data.css is string 
        && data.css.size() <= 1048576
        && data.js is string 
        && data.js.size() <= 1048576
        && data.updatesCount is int
        && data.visitorsCount is int
        && data.isPublished is bool
        && data.publishedUrl is string
        && data.publishedUrl.size() <= 1024;
    }

    // Isolated User Projects nested under users subcollection
    match /users/{userId}/projects/{projectId} {
      
      // Get: must be signed-in owner
      allow get: if isOwner(userId) && isValidId(projectId);

      // List: restricted strictly to the authenticated user's own subset
      allow list: if isOwner(userId);

      // Create: owner can write only valid schema matching their uid
      allow create: if isOwner(userId) 
        && isValidId(projectId) 
        && isValidUserProject(incoming(), userId)
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      // Update: allow owner to modify content, keeping immutables intact
      allow update: if isOwner(userId) 
        && isValidId(projectId) 
        && isValidUserProject(incoming(), userId)
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'name', 'description', 'html', 'css', 'js', 
            'updatesCount', 'visitorsCount', 'isPublished', 
            'publishedUrl', 'updatedAt', 'isPublic'
          ])
        );

      // Delete: must be matching owner
      allow delete: if isOwner(userId) && isValidId(projectId);
    }

    // Public community projects accessible to everyone globally
    match /public_projects/{projectId} {
      allow get: if isValidId(projectId);
      allow list: if true;
      allow create: if isSignedIn() 
        && isValidId(projectId) 
        && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn()
        && isValidId(projectId)
        && existing().userId == request.auth.uid;
      allow update: if isSignedIn()
        && isValidId(projectId)
        && (
          // Case 1: Owner updates their own project
          (existing().userId == request.auth.uid && incoming().userId == request.auth.uid)
          ||
          // Case 2: Any authenticated user likes/unlikes or increments clonesCount
          (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'likesCount']) || incoming().diff(existing()).affectedKeys().hasOnly(['clonesCount']))
        );

      // Subcollection of comments for discussing projects
      match /comments/{commentId} {
        allow read, list: if isValidId(projectId);
        allow create: if isSignedIn()
          && isValidId(projectId)
          && isValidId(commentId)
          && incoming().userId == request.auth.uid
          && incoming().projectId == projectId
          && incoming().commentId == commentId
          && incoming().text is string
          && incoming().text.size() <= 2000
          && incoming().userName is string
          && incoming().userName.size() <= 128
          && incoming().createdAt == request.time;
        allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      }
    }
  }
}
